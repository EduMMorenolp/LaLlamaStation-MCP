# Configuración de Ollama MCP Server
# Copia este archivo a .env y rellena los valores

# Token de autenticación de ngrok (Obtenlo en dashboard.ngrok.com)
NGROK_AUTHTOKEN=tu_token_aqui

# API Key para proteger tu MCP Server remotamente
API_KEY=mcp_clave_segura_123

# Puerto de la aplicación (interno del contenedor)
APP_PORT=3016

# Puerto de comunicación para el Cerebro MCP
BRAIN_PORT=3015

# Ruta absoluta del proyecto en el HOST (Windows) para la auto-sincronización de Antigravity
# Ejemplo: D:/Proyectos/LaLlamaOllama
HOST_PROJECT_PATH=C:/ruta/a/tu/proyecto

# URL de Ollama (generalmente no necesita cambiarse en Docker)
OLLAMA_URL=http://ollama:11434

# Modelos a descargar automáticamente cuando el backend arranca (separados por coma, sin espacios)
# Deja vacío para desactivar. Los modelos ya descargados se omiten automáticamente.
# OLLAMA_AUTO_PULL=llama3.2:3b,qwen2.5-coder:7b
